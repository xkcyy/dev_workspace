{
  "name": "docs-wiki",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "sync-content": "node ./scripts/sync-content.mjs",
    "dev": "npm run sync-content && fumadocs-mdx && next dev",
    "build": "npm run sync-content && fumadocs-mdx && next build",
    "start": "next start",
    "check": "npm run sync-content && fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "npm run sync-content && fumadocs-mdx"
  },
  "dependencies": {
    "@orama/orama": "^3.1.12",
    "@orama/tokenizers": "^3.1.12",
    "fumadocs-core": "16.7.10",
    "fumadocs-mdx": "14.2.11",
    "fumadocs-ui": "16.7.10",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
}
