---
import { getCollection, render } from "astro:content";
import WikiLayout from "../../layouts/WikiLayout.astro";
import { entrySlug, sortEntries, toTagHref } from "../../lib/wiki";

export async function getStaticPaths() {
  const entries = await getCollection("wiki", ({ data }) => !data.draft);

  return entries.map((entry) => ({
    params: { slug: entrySlug(entry) },
    props: { entry, entries: sortEntries(entries) }
  }));
}

const { entry, entries } = Astro.props;
const { Content } = await render(entry);
const currentSlug = entrySlug(entry);
---

<WikiLayout
  title={entry.data.title}
  description={entry.data.summary}
  entries={entries}
  currentSlug={currentSlug}
>
  <article class="doc">
    <header class="doc-header">
      <p class="eyebrow">{entry.data.section}</p>
      <h1>{entry.data.title}</h1>
      {entry.data.summary && <p class="lede">{entry.data.summary}</p>}
      {
        entry.data.tags.length > 0 && (
          <div class="tag-row">
            {entry.data.tags.map((tag) => (
              <a class="tag-chip" href={toTagHref(tag)}>
                #{tag}
              </a>
            ))}
          </div>
        )
      }
    </header>
    <Content />
  </article>
</WikiLayout>
