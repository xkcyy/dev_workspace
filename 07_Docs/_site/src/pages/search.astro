---
import { getCollection } from "astro:content";
import WikiLayout from "../layouts/WikiLayout.astro";
import { sortEntries, withBase } from "../lib/wiki";

const entries = sortEntries(await getCollection("wiki", ({ data }) => !data.draft));
const bundlePath = withBase("pagefind/");
const scriptPath = withBase("pagefind/pagefind-ui.js");
const stylePath = withBase("pagefind/pagefind-ui.css");
---

<WikiLayout title="Search" description="Search the wiki." entries={entries}>
  <section class="hero">
    <p class="eyebrow">Search</p>
    <h1>全文检索整个 wiki。</h1>
    <p class="lede">
      搜索索引由 Pagefind 在构建后生成，部署到 GitHub Pages 后也保持纯静态。
    </p>
  </section>

  <section class="panel search-panel">
    <p class="search-hint">
      开发模式下如果还没有运行过 <code>npm run build</code>，这里会提示索引尚未生成。
    </p>
    <div id="search"></div>
    <p id="search-status" class="search-empty" hidden></p>
  </section>

  <script is:inline define:vars={{ bundlePath, scriptPath, stylePath }}>
    const searchRoot = document.querySelector("#search");
    const status = document.querySelector("#search-status");

    const setStatus = (message) => {
      if (!status) {
        return;
      }

      status.hidden = false;
      status.textContent = message;
    };

    const loadStyle = (href) => {
      if (document.querySelector(`link[data-pagefind-style="${href}"]`)) {
        return;
      }

      const link = document.createElement("link");
      link.rel = "stylesheet";
      link.href = href;
      link.dataset.pagefindStyle = href;
      document.head.appendChild(link);
    };

    const loadScript = (src) =>
      new Promise((resolve, reject) => {
        if (window.PagefindUI) {
          resolve();
          return;
        }

        const script = document.createElement("script");
        script.src = src;
        script.async = true;
        script.onload = resolve;
        script.onerror = reject;
        document.head.appendChild(script);
      });

    window.addEventListener("DOMContentLoaded", async () => {
      if (!searchRoot) {
        return;
      }

      try {
        loadStyle(stylePath);
        await loadScript(scriptPath);

        new window.PagefindUI({
          element: "#search",
          bundlePath,
          showSubResults: true,
          resetStyles: false,
          pageSize: 8
        });
      } catch {
        setStatus("全文索引尚未生成。先运行 `npm run build`，或直接查看 GitHub Pages 上的已部署站点。");
      }
    });
  </script>
</WikiLayout>
