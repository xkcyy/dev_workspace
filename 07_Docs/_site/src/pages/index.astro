---
import { getCollection } from "astro:content";
import WikiLayout from "../layouts/WikiLayout.astro";
import {
  entrySlug,
  groupEntriesBySection,
  SECTION_LABELS,
  sortEntries,
  toTagHref,
  toWikiHref
} from "../lib/wiki";

const entries = sortEntries(await getCollection("wiki", ({ data }) => !data.draft));
const groupedEntries = groupEntriesBySection(entries);
const tags = [...new Set(entries.flatMap((entry) => entry.data.tags))].sort((left, right) =>
  left.localeCompare(right, "zh-CN")
);
---

<WikiLayout
  title="Home"
  description="A static Markdown wiki built for GitHub Pages."
  entries={entries}
>
  <section class="hero">
    <p class="eyebrow">Static Markdown Wiki</p>
    <h1>把内容放进 Markdown，把站点交给前端构建。</h1>
    <p class="lede">
      顶层目录直接承载文档内容，站点代码只放在 <code>_site/</code>。推送到 GitHub 后，
      这个 wiki 会通过 Pages 自动构建并对外发布。
    </p>
  </section>

  <section class="panel">
    <div class="panel-head">
      <h2>Browse by Section</h2>
      <a href="./search/">Open search</a>
    </div>
    {
      groupedEntries.map(([section, sectionEntries]) => (
        <section class="section-block">
          <h3>{SECTION_LABELS[section] ?? section}</h3>
          <div class="card-grid">
            {sectionEntries.map((entry) => (
              <article class="wiki-card">
                <h4>
                  <a href={toWikiHref(entrySlug(entry))}>{entry.data.title}</a>
                </h4>
                <p>{entry.data.summary}</p>
              </article>
            ))}
          </div>
        </section>
      ))
    }
  </section>

  <section class="panel">
    <div class="panel-head">
      <h2>Tag Index</h2>
    </div>
    <div class="tag-row">
      {tags.map((tag) => (
        <a class="tag-chip" href={toTagHref(tag)}>
          #{tag}
        </a>
      ))}
    </div>
  </section>
</WikiLayout>
